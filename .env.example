# Skopiuj do .env.local i uzupełnij wartościami z panelu Supabase
# (Project Settings → API)
VITE_SUPABASE_URL=https://<twoj-projekt>.supabase.co
VITE_SUPABASE_ANON_KEY=<publishable_lub_anon_key>

# Klucz xAI (Grok) NIE jest zmienną klienta — to sekret Edge Functions (agent, transcribe).
# Ustaw go po stronie Supabase, nie w .env.local:
#   supabase secrets set XAI_API_KEY=<twoj_klucz_xai>
# (lub w panelu: Edge Functions → Secrets)

# APP_ORIGINS — allowlista origin dla CORS funkcji obsługujących aplikację
# (agent, tokens, tts, transcribe). CSV; domyślnie domena prod + Vite dev.
# Publiczne API (`api`) i webhook (`embed-entry`) celowo zostają na Origin: *.
# To sekret Edge Functions, nie zmienna klienta:
#   supabase secrets set APP_ORIGINS="https://twoja-domena.vercel.app,http://localhost:5173"
